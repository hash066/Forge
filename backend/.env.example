# =========================================================================
# DevForge Backend Configuration (example)
# Copy to .env and fill in real secrets. NEVER commit real credentials.
# =========================================================================

# --- AWS & Bedrock ---
AWS_REGION=eu-north-1
ANTHROPIC_MODEL_ID=anthropic.claude-sonnet-4-20250514-v1:0
AWS_ACCESS_KEY_ID=your-access-key
AWS_SECRET_ACCESS_KEY=your-secret-key

# AWS account (informational; for IAM/STS scoping). Source: aws.txt
AWS_ACCOUNT_ID=617987691289

# --- Upstream AWS API Gateway endpoints (eu-north-1) ---
# devforge-api (ghwl6o43ch): blueprint / diagram / predict-scale / quiz / detect-patterns / health
DEVFORGE_API_BASE_URL=https://ghwl6o43ch.execute-api.eu-north-1.amazonaws.com/dev
# infra-ai-api (1plv9rmbhb): analyze / risk / drift / cost / security
INFRA_AI_API_BASE_URL=https://1plv9rmbhb.execute-api.eu-north-1.amazonaws.com/dev
# devforge-realtime (6fhd8botk8): WebSocket + @connections management
REALTIME_WSS_URL=wss://6fhd8botk8.execute-api.eu-north-1.amazonaws.com/dev/
REALTIME_MANAGEMENT_URL=https://6fhd8botk8.execute-api.eu-north-1.amazonaws.com/dev/@connections

# --- API Security ---
API_KEY_SECRET=dev-local-key
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:8000

# --- Cache (ElastiCache Redis OSS: devforge-redis) ---
REDIS_HOST=devforge-redis.pkcts0.ng.0001.eun1.cache.amazonaws.com
REDIS_PORT=6379
REDIS_URL=redis://devforge-redis.pkcts0.ng.0001.eun1.cache.amazonaws.com:6379

# --- Database (RDS — fill master credentials in real .env, not here) ---
DATABASE_URL=postgresql://user:password@localhost:5432/devforge

# --- Server ---
HOST=0.0.0.0
PORT=8000
DEBUG=true
