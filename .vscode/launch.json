{
	"version": "0.2.0",
	"configurations": [
		{
			"name": "Run Extension (DevForge)",
			"type": "extensionHost",
			"request": "launch",
			"args": [
				"--extensionDevelopmentPath=${workspaceFolder}"
			],
			"outFiles": [
				"${workspaceFolder}/forge/dist/**/*.js"
			],
			"preLaunchTask": "npm: compile"
		},
		{
			"name": "Launch Extension (Forge Folder)",
			"type": "extensionHost",
			"request": "launch",
			"args": [
				"--extensionDevelopmentPath=${workspaceFolder}/forge"
			],
			"outFiles": [
				"${workspaceFolder}/forge/dist/**/*.js"
			],
			"preLaunchTask": "npm: compile"
		}
	]
}
