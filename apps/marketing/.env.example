# Marketing site environment variables.
# Copy this to .env.local and fill in real values for local dev.
# Vercel pulls production values from project settings.
NEXT_PUBLIC_SITE_URL=http://localhost:3000
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_API_URL=http://localhost:8000

# Marketplace links — replace with real listing URLs once published
NEXT_PUBLIC_VSCODE_EXTENSION_URL=https://marketplace.visualstudio.com/items?itemName=devforge.devforge
NEXT_PUBLIC_KIRO_EXTENSION_URL=https://kiro.dev/extensions/devforge

# Demo booking
NEXT_PUBLIC_DEMO_URL=https://cal.com/devforge/demo
