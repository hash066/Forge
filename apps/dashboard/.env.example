# DevForge OS dashboard — copy to .env.local for local dev.
# The control plane base URL (REST + WebSocket are derived from it).
NEXT_PUBLIC_API_URL=http://localhost:8000
# Tenant the dashboard scopes to (sent as X-Tenant-Id).
NEXT_PUBLIC_TENANT_ID=demo
# Cluster label shown in the UI / sent on demo snapshots.
NEXT_PUBLIC_CLUSTER=kind-devforge
