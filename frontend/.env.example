# =========================================================================
# DevForge Frontend Configuration (example)
# Vite reads variables prefixed with VITE_ at build time.
# Copy to .env and override per environment as needed.
# =========================================================================

# Local FastAPI control plane (used when developing against the local backend).
VITE_BACKEND_URL=http://localhost:8000
VITE_API_KEY=dev-local-key

# --- Upstream AWS API Gateway endpoints (eu-north-1) ---
# devforge-api (ghwl6o43ch): blueprint / diagram / predict-scale / quiz / detect-patterns / health
VITE_DEVFORGE_API_BASE_URL=https://ghwl6o43ch.execute-api.eu-north-1.amazonaws.com/dev
# infra-ai-api (1plv9rmbhb): analyze / risk / drift / cost / security
VITE_INFRA_AI_API_BASE_URL=https://1plv9rmbhb.execute-api.eu-north-1.amazonaws.com/dev
# devforge-realtime (6fhd8botk8): WebSocket
VITE_REALTIME_WSS_URL=wss://6fhd8botk8.execute-api.eu-north-1.amazonaws.com/dev/
