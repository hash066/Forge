# DevForge Control Plane — environment variables.
# Copy to .env for local dev. Production values are managed via AWS Secrets Manager.
# -----------------------------------------------------------------------------

# App
APP_ENV=development
DEBUG=true
HOST=0.0.0.0
PORT=8000
LOG_LEVEL=INFO

# CORS — comma-separated origins
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173

# Auth — Clerk JWT verification
CLERK_PUBLISHABLE_KEY=
CLERK_SECRET_KEY=
CLERK_JWT_ISSUER=https://your-tenant.clerk.accounts.dev

# Internal API key (CLI + extension fallback). Rotate via Secrets Manager in prod.
INTERNAL_API_KEY=dev-local-key

# Database — Postgres
DATABASE_URL=postgresql+asyncpg://devforge:devforge@localhost:5432/devforge

# Redis (ElastiCache in prod)
REDIS_URL=redis://localhost:6379/0

# AWS
AWS_REGION=eu-north-1
AWS_BEDROCK_MODEL_ID=anthropic.claude-sonnet-4-20250514-v1:0
S3_BLUEPRINT_BUCKET=devforge-blueprints-dev

# Rate limits (per tenant per minute)
RATE_LIMIT_DEFAULT=60
RATE_LIMIT_ANALYSIS=20
