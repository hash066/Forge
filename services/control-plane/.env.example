# DevForge OS control plane — environment configuration.
# Copy to .env and fill in. Everything has a safe default for local/demo use.
# -----------------------------------------------------------------------------

# ── AI provider ────────────────────────────────────────────────────────────────
# openai (default) | bedrock | offline. With no OPENAI_API_KEY the control plane
# automatically falls back to the deterministic SRE engine (demo still works).
AI_PROVIDER=openai
OPENAI_API_KEY=
OPENAI_MODEL=gpt-5.5
# OPENAI_BASE_URL=            # optional: Azure / OpenAI-compatible gateway

# ── App ──────────────────────────────────────────────────────────────────────
APP_ENV=development
DEBUG=true
HOST=0.0.0.0
PORT=8000
LOG_LEVEL=INFO

# CORS — comma-separated origins (dashboard runs on :3001, marketing on :3000)
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:3001

# Internal API key (CLI + extension fallback). Rotate via Secrets Manager in prod.
INTERNAL_API_KEY=dev-local-key

# ── Database ───────────────────────────────────────────────────────────────────
# Default is a zero-setup SQLite file. Set a Postgres DSN for production:
#   DATABASE_URL=postgresql+asyncpg://devforge:devforge@localhost:5432/devforge
DATABASE_URL=sqlite+aiosqlite:///./devforge.db

# ── Redis (optional cache) ──────────────────────────────────────────────────────
# REDIS_URL=redis://localhost:6379/0

# ── Auth (Clerk JWT — Phase 1, optional today) ──────────────────────────────────
CLERK_PUBLISHABLE_KEY=
CLERK_SECRET_KEY=
CLERK_JWT_ISSUER=

# ── AWS (only when AI_PROVIDER=bedrock, or for the Pricing API) ──────────────────
AWS_REGION=ap-south-1
AWS_BEDROCK_MODEL_ID=anthropic.claude-sonnet-4-20250514-v1:0
S3_BLUEPRINT_BUCKET=devforge-blueprints-dev

# Rate limits (per tenant per minute)
RATE_LIMIT_DEFAULT=60
RATE_LIMIT_ANALYSIS=20
