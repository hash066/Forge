{
  "name": "forge",
  "displayName": "Forge",
  "description": "Architecture-first AI IDE extension",
  "version": "0.0.1",
  "publisher": "devforge",
  "repository": {
    "type": "git",
    "url": "https://github.com/devforge/devforge"
  },
  "engines": {
    "vscode": "^1.109.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [],
  "main": "./dist/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "devforge.analyzeCode",
        "title": "DevForge: Analyze Code",
        "category": "DevForge"
      },
      {
        "command": "devforge.showDashboard",
        "title": "DevForge: Show Dashboard",
        "category": "DevForge"
      },
      {
        "command": "devforge.createBlueprint",
        "title": "DevForge: Create Blueprint",
        "category": "DevForge"
      }
    ],
    "viewsContainers": {
      "activitybar": [
        {
          "id": "devforge-sidebar",
          "title": "DevForge",
          "icon": "media/rocket.svg"
        }
      ]
    },
    "views": {
      "devforge-sidebar": [
        {
          "type": "webview",
          "id": "devforge-left-panel",
          "name": "DevForge"
        }
      ]
    },
    "configuration": {
      "title": "DevForge",
      "properties": {
        "devforge.apiEndpoint": {
          "type": "string",
          "default": "https://api.devforge.com",
          "description": "API Endpoint URL for DevForge services."
        },
        "devforge.demoMode": {
          "type": "boolean",
          "default": true,
          "description": "When enabled, DevForge uses realistic mock data instead of real API calls."
        }
      }
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run package",
    "compile": "npm run check-types && npm run lint && node esbuild.js",
    "watch": "npm-run-all -p watch:*",
    "watch:esbuild": "node esbuild.js --watch",
    "watch:tsc": "tsc --noEmit --watch --project tsconfig.json",
    "package": "npm run check-types && npm run lint && node esbuild.js --production",
    "compile-tests": "tsc -p . --outDir out",
    "watch-tests": "tsc -p . -w --outDir out",
    "pretest": "npm run compile-tests && npm run compile && npm run lint",
    "check-types": "tsc --noEmit",
    "lint": "eslint src",
    "test": "vscode-test"
  },
  "devDependencies": {
    "@types/mocha": "^10.0.10",
    "@types/node": "22.x",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@types/vscode": "^1.109.0",
    "@vscode/test-cli": "^0.0.12",
    "@vscode/test-electron": "^2.5.2",
    "esbuild": "^0.27.3",
    "eslint": "^9.39.3",
    "npm-run-all": "^4.1.5",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.56.1"
  },
  "dependencies": {
    "lucide-react": "^0.577.0",
    "reactflow": "^11.11.4",
    "recharts": "^3.8.0"
  }
}