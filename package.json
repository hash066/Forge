{
  "name": "devforge",
  "displayName": "DevForge",
  "description": "Architecture-first AI IDE extension — real-time security scanning, drift detection, pattern analysis, cost estimation, and AI-powered mentorship.",
  "version": "0.1.0",
  "publisher": "devforge",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/sammy-20-wqz/architecture-first-ide-kiro"
  },
  "homepage": "https://github.com/sammy-20-wqz/architecture-first-ide-kiro#readme",
  "categories": [
    "Other",
    "Linters",
    "Education",
    "Machine Learning"
  ],
  "keywords": [
    "architecture",
    "ai",
    "security",
    "code analysis",
    "developer tools"
  ],
  "icon": "forge/media/rocket.svg",
  "engines": {
    "vscode": "^1.80.0"
  },
  "main": "./forge/dist/extension.js",
  "activationEvents": [],
  "contributes": {
    "commands": [
      {
        "command": "devforge.analyzeCode",
        "title": "DevForge: Analyze Code",
        "category": "DevForge"
      },
      {
        "command": "devforge.showDashboard",
        "title": "DevForge: Show Dashboard",
        "category": "DevForge"
      },
      {
        "command": "devforge.createBlueprint",
        "title": "DevForge: Create Blueprint",
        "category": "DevForge"
      }
    ],
    "viewsContainers": {
      "activitybar": [
        {
          "id": "devforge-sidebar",
          "title": "DevForge",
          "icon": "forge/media/rocket.svg"
        }
      ]
    },
    "views": {
      "devforge-sidebar": [
        {
          "type": "webview",
          "id": "devforge-left-panel",
          "name": "DevForge"
        }
      ]
    },
    "configuration": {
      "title": "DevForge",
      "properties": {
        "devforge.apiEndpoint": {
          "type": "string",
          "default": "https://api.devforge.com",
          "description": "API Endpoint URL for DevForge services."
        },
        "devforge.preferredAiModel": {
          "type": "string",
          "enum": [
            "claude",
            "gemini",
            "grok"
          ],
          "default": "claude",
          "description": "The AI model to use for architecture assistance."
        },
        "devforge.geminiApiKey": {
          "type": "string",
          "default": "",
          "description": "API Key for Google Gemini."
        },
        "devforge.grokApiKey": {
          "type": "string",
          "default": "",
          "description": "API Key for xAI Grok."
        }
      }
    }
  },
  "scripts": {
    "compile": "webpack && cd forge && node esbuild.js",
    "watch": "webpack --watch"
  },
  "dependencies": {
    "@aws-sdk/client-bedrock-runtime": "^3.1003.0",
    "@aws-sdk/client-lambda": "^3.1003.0",
    "axios": "^1.13.6",
    "chokidar": "^5.0.0",
    "lucide-react": "^0.577.0",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "reactflow": "^11.11.4",
    "recharts": "^3.8.0",
    "tree-sitter": "^0.25.0",
    "tree-sitter-javascript": "^0.25.0",
    "tree-sitter-python": "^0.25.0",
    "tree-sitter-typescript": "^0.23.2"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4.2.1",
    "@types/node": "^25.3.5",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "autoprefixer": "^10.4.27",
    "css-loader": "^7.1.4",
    "postcss": "^8.5.8",
    "postcss-loader": "^8.2.1",
    "style-loader": "^4.0.0",
    "tailwindcss": "^4.2.1",
    "ts-loader": "^9.5.4",
    "typescript": "^5.9.3",
    "webpack": "^5.105.4",
    "webpack-cli": "^6.0.1"
  }
}